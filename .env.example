# ─────────────────────────────────────────────
# Hostinger FTP Deployment Credentials
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and will NEVER be committed.
#
# These same values must also be added as GitHub
# repository secrets for the CI/CD workflow to work:
# → github.com/ramekwals761/traveldailypost
#   Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────

FTP_SERVER=your-hostinger-ftp-host        # e.g. ftp.traveldailypost.com
FTP_USERNAME=your-ftp-username            # e.g. u123456789
FTP_PASSWORD=your-ftp-password
